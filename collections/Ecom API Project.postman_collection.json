              "});\r",
              "\r",
              "// 9. Log Product Details\r",
              "console.log(\"Product ID:\", jsonData.id);\r",
              "console.log(\"Product Name:\", jsonData.title);\r",
              "console.log(\"Product Price:\", jsonData.price);"
