    {
      "name": "Get User Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse Response\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// 1. Status Code Validation\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Response Time Validation\r",
              "pm.test(\"Response time is less than 2000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// 3. Content-Type Validation\r",
              "pm.test(\"Content-Type is application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 4. Response Body Validation\r",
              "pm.test(\"Response body should not be empty\", function () {\r",
              "    pm.expect(jsonData).to.not.be.empty;\r",
              "});\r",
              "\r",
              "// 5. Validate Required Fields\r",
              "pm.test(\"User profile contains required fields\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.expect(jsonData).to.have.property(\"firstName\");\r",
              "    pm.expect(jsonData).to.have.property(\"lastName\");\r",
              "    pm.expect(jsonData).to.have.property(\"email\");\r",
              "    pm.expect(jsonData).to.have.property(\"username\");\r",
              "});\r",
              "\r",
              "// 6. Validate Data Types\r",
              "pm.test(\"User profile fields have correct data types\", function () {\r",
              "    pm.expect(jsonData.id).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.firstName).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.lastName).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.email).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.username).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "// 7. Validate Email Format\r",
              "pm.test(\"Email should contain @ symbol\", function () {\r",
              "    pm.expect(jsonData.email).to.include(\"@\");\r",
              "});\r",
              "\r",
              "// 8. Verify Token Exists\r",
              "pm.test(\"Access token exists in Environment\", function () {\r",
              "    pm.expect(pm.environment.get(\"token\")).to.exist;\r",
              "});\r",
              "\r",
              "// 9. Save User ID\r",
              "pm.environment.set(\"user_id\", jsonData.id);\r",
              "\r",
              "// 10. Verify User ID Stored\r",
              "pm.test(\"User ID stored successfully\", function () {\r",
              "    pm.expect(pm.environment.get(\"user_id\")).to.eql(jsonData.id.toString());\r",
              "});\r",
              "\r",
              "// Console Logs\r",
              "console.log(\"User ID:\", jsonData.id);\r",
              "console.log(\"User Name:\", jsonData.firstName + \" \" + jsonData.lastName);\r",
              "console.log(\"Email:\", jsonData.email);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse Response\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "// 1. Status Code Validation\r",
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Response Time Validation\r",
              "pm.test(\"Response time is less than 2000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "// 3. Content-Type Validation\r",
              "pm.test(\"Content-Type is application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "// 4. Response Body Validation\r",
              "pm.test(\"Products array should not be empty\", function () {\r",
              "    pm.expect(jsonData.products).to.be.an(\"array\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "// 5. Validate First Product Fields\r",
              "pm.test(\"First product contains required fields\", function () {\r",
              "    const product = jsonData.products[0];\r",
              "\r",
              "    pm.expect(product).to.have.property(\"id\");\r",
              "    pm.expect(product).to.have.property(\"title\");\r",
              "    pm.expect(product).to.have.property(\"description\");\r",
              "    pm.expect(product).to.have.property(\"price\");\r",
              "    pm.expect(product).to.have.property(\"category\");\r",
              "});\r",
              "\r",
              "// 6. Data Type Validation\r",
              "pm.test(\"First product data types are correct\", function () {\r",
              "    const product = jsonData.products[0];\r",
              "\r",
              "    pm.expect(product.id).to.be.a(\"number\");\r",
              "    pm.expect(product.title).to.be.a(\"string\");\r",
              "    pm.expect(product.description).to.be.a(\"string\");\r",
              "    pm.expect(product.price).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// 7. Save Product ID in Environment Variable\r",
              "pm.environment.set(\"product_id\", jsonData.products[0].id);\r",
              "\r",
              "// 8. Verify Environment Variable Saved\r",
              "pm.test(\"Product ID stored in Environment Variable\", function () {\r",
              "    pm.expect(pm.environment.get(\"product_id\")).to.eql(jsonData.products[0].id.toString());\r",
              "});\r",
              "\r",
              "// 9. Log Product ID\r",
              "console.log(\"Product ID:\", pm.environment.get(\"product_id\"));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}//products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "",
            "products"
          ]
        }
      },
      "response": []
    },
